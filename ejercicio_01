#include<iostream>
#include<iomanip>

int main(){

    double celsius,fahrenheit,kelvin,rankine;

    std::cout<<"escriba temperatura en CELSIUS para convertirlo"<<std::endl;
    std::cin>>celsius;

    kelvin = celsius + 273.15;
    fahrenheit = (celsius * 9/5) + 32;
    rankine = (celsius * 9/5) + 491.67;

    std::cout <<std::fixed << std::setprecision(2);
    std:: cout<<"KELVIN"  << kelvin<< "K"<<std::endl;
    std:: cout<<"FAHRENHEIT" << fahrenheit << "F" <<std::endl;
    std::cout<< "RANKINE" <<rankine<< "R" <<std::endl;
                

 return 0;

}
